<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Stream Connect - Simplified online meeting software with enterprise-grade security, perfect for a work-wherever world. Start your free video conference today.">
    <title>Stream Connect - Engaging and Collaborative Web Conferencing</title>
    <link rel="icon" type="image/png" href="/logo.png">
    <link rel="stylesheet" href="/stylesheets/home.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>
<body>

    <!-- ==================== NAVBAR ==================== -->
    <nav class="navbar" id="navbar">
        <div class="container">
            <a href="/" class="nav-logo" id="nav-logo">
                <img src="/logo.png" alt="Stream Connect" class="nav-logo-img">
                Stream Connect
            </a>

            <div class="nav-links" id="nav-links">
                <a href="#features">Features</a>
                <a href="#stats">Pricing</a>
                <a href="#testimonials">Resources</a>
                <a href="#download">Download</a>
            </div>

            <div class="nav-actions">
                <% if(user) { %>
                    <div class="user-profile">
                        <div class="user-avatar"><%= user.name.charAt(0).toUpperCase() %></div>
                        <span class="user-name"><%= user.name %></span>
                        <button class="nav-login" onclick="logout()">Logout</button>
                    </div>
                <% } else { %>
                    <a href="#" class="nav-login" onclick="openModal('loginModal')">Login</a>
                    <button class="btn-signup" id="btn-signup" onclick="openModal('signupModal')">Sign up</button>
                <% } %>
            </div>

            <button class="nav-menu-toggle" id="nav-menu-toggle" aria-label="Toggle menu">
                <span></span>
                <span></span>
                <span></span>
            </button>
        </div>
    </nav>

    <!-- ==================== AUTHENTICATION MODALS ==================== -->
    <!-- Login Modal -->
    <div class="auth-modal" id="loginModal">
        <div class="auth-modal-content">
            <button class="auth-close" onclick="closeModal('loginModal')"><i class="fas fa-times"></i></button>
            <div class="auth-header">
                <img src="/logo.png" alt="Stream Connect">
                <h2>Welcome Back</h2>
                <p>Login to start or join a meeting</p>
            </div>
            <form id="loginForm" class="auth-form" onsubmit="handleLogin(event)">
                <div class="auth-input-group">
                    <label>Email Address</label>
                    <div class="auth-input-wrapper">
                        <i class="fas fa-envelope"></i>
                        <input type="email" id="loginEmail" required placeholder="you@example.com">
                    </div>
                </div>
                <div class="auth-input-group">
                    <label>Password</label>
                    <div class="auth-input-wrapper">
                        <i class="fas fa-lock"></i>
                        <input type="password" id="loginPassword" required placeholder="••••••••">
                    </div>
                </div>
                <div id="loginError" class="auth-error"></div>
                <button type="submit" class="btn-primary auth-submit">Login</button>
                <div class="auth-footer">
                    Don't have an account? <a href="#" onclick="switchModal('loginModal', 'signupModal')">Sign up</a>
                </div>
            </form>
        </div>
    </div>

    <!-- Signup Modal -->
    <div class="auth-modal" id="signupModal">
        <div class="auth-modal-content">
            <button class="auth-close" onclick="closeModal('signupModal')"><i class="fas fa-times"></i></button>
            <div class="auth-header">
                <img src="/logo.png" alt="Stream Connect">
                <h2>Create Account</h2>
                <p>Join Stream Connect today</p>
            </div>
            <form id="signupForm" class="auth-form" onsubmit="handleSignup(event)">
                <div class="auth-input-group">
                    <label>Full Name</label>
                    <div class="auth-input-wrapper">
                        <i class="fas fa-user"></i>
                        <input type="text" id="signupName" required placeholder="John Doe">
                    </div>
                </div>
                <div class="auth-input-group">
                    <label>Email Address</label>
                    <div class="auth-input-wrapper">
                        <i class="fas fa-envelope"></i>
                        <input type="email" id="signupEmail" required placeholder="you@example.com">
                    </div>
                </div>
                <div class="auth-input-group">
                    <label>Password</label>
                    <div class="auth-input-wrapper">
                        <i class="fas fa-lock"></i>
                        <input type="password" id="signupPassword" required placeholder="••••••••">
                    </div>
                </div>
                <div id="signupError" class="auth-error"></div>
                <button type="submit" class="btn-primary auth-submit">Sign up</button>
                <div class="auth-footer">
                    Already have an account? <a href="#" onclick="switchModal('signupModal', 'loginModal')">Login</a>
                </div>
            </form>
        </div>
    </div>

    <% if (!user) { %>
    <!-- ==================== HERO SECTION ==================== -->
    <section class="hero" id="hero">
        <div class="container">
            <div class="hero-badge">
                <span class="hero-badge-dot"></span>
                New: AI-powered noise cancellation is here
            </div>

            <h1 class="hero-title">
                Engaging <span class="italic-accent">and</span> collaborative<br>
                Web Conferencing<span class="highlight">*</span>
            </h1>

            <p class="hero-subtitle">
                Simplified online meeting software with enterprise-grade security, perfect for a work-wherever world.
            </p>

            <!-- CTA with Meeting Forms -->
            <div class="hero-cta">
                <% if(user) { %>
                    <form action="/newMeeting" method="POST" style="display:contents;">
                        <div class="hero-input-group">
                            <input type="text" name="username" id="hero-name" value="<%= user.name %>" readonly style="background: rgba(255,255,255,0.05); color: #9ca3af; cursor: not-allowed;">
                            <button type="submit" class="btn-primary">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="23 7 16 12 23 17 23 7"></polygon><rect x="1" y="5" width="15" height="14" rx="2" ry="2"></rect></svg>
                                New Meeting
                            </button>
                        </div>
                    </form>

                    <span style="color: var(--color-text-muted); font-size: 0.9rem;">or</span>

                    <form action="/joinMeeting" method="POST" style="display:flex; gap:8px; flex-wrap:wrap; align-items:center; justify-content:center;">
                        <input type="hidden" name="username" id="join-name-hidden" value="<%= user.name %>">
                        <div class="hero-input-group" style="width:260px;">
                            <input type="text" name="meetingCode" placeholder="Enter meeting code" required>
                            <button type="submit" class="btn-primary" style="background:var(--color-green);">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"></path><polyline points="10 17 15 12 10 7"></polyline><line x1="15" y1="12" x2="3" y2="12"></line></svg>
                                Join
                            </button>
                        </div>
                    </form>
                <% } else { %>
                    <div class="hero-input-group" style="width: 100%; max-width: 400px; padding: 4px; background: rgba(255, 255, 255, 0.05); border: 1px solid rgba(255, 255, 255, 0.1);">
                        <button class="btn-primary" style="width: 100%; justify-content: center;" onclick="openModal('loginModal')">
                            <i class="fas fa-lock" style="margin-right: 8px;"></i>
                            Login to Start or Join a Meeting
                        </button>
                    </div>
                <% } %>
            </div>

            <!-- Hero Mockup - Video Call Interface -->
            <div class="hero-mockup">
                <!-- Floating notification card -->
                <div class="hero-float-card left">
                    <div class="hero-float-avatar" style="background: linear-gradient(135deg, #667eea, #764ba2); display:flex; align-items:center; justify-content:center; color:white; font-weight:700;">AK</div>
                    <div class="hero-float-info">
                        <div class="hero-float-name">Arjun Kumar</div>
                        <div class="hero-float-label">Waiting room...</div>
                    </div>
                    <div class="hero-float-actions">
                        <div class="hero-float-reject"><i class="fas fa-times"></i></div>
                        <div class="hero-float-accept"><i class="fas fa-check"></i></div>
                    </div>
                </div>

                <div class="hero-mockup-main">
                    <!-- Mockup Top Bar -->
                    <div class="hero-mockup-header">
                        <div class="hero-mockup-header-left">
                            <div class="hero-mockup-title-pill">
                                <span class="dot"></span>
                                Team Standup — 08:45
                            </div>
                            <div class="hero-mockup-action-btn"><i class="fas fa-lock" style="margin-right:4px; font-size:0.65rem;"></i> Encrypted</div>
                        </div>
                        <div class="hero-mockup-header-right">
                            <div class="hero-mockup-action-btn"><i class="fas fa-user-plus" style="margin-right:4px;"></i> Invite</div>
                            <div class="hero-mockup-action-btn"><i class="fas fa-link" style="margin-right:4px;"></i> Copy link</div>
                            <div class="hero-mockup-icon-btn"><i class="fas fa-th-large"></i></div>
                            <div class="hero-mockup-icon-btn"><i class="fas fa-ellipsis-h"></i></div>
                        </div>
                    </div>

                    <!-- Video Grid -->
                    <div class="video-call-grid">
                        <!-- Main / large tile -->
                        <div class="video-tile main-tile">
                            <video src="/videos/doc.mp4" autoplay muted loop playsinline></video>
                            <div class="video-tile-overlay">
                                <div class="video-tile-name"><i class="fas fa-microphone" style="margin-right:6px; font-size:0.65rem;"></i> Priya Sharma <span class="you-badge">You</span></div>
                            </div>
                            <div class="video-tile-pin"><i class="fas fa-thumbtack"></i></div>
                        </div>

                    </div>

                    <!-- Bottom Control Bar -->
                    <div class="video-call-controls">
                        <div class="video-controls-left">
                            <span class="meeting-timer"><i class="fas fa-circle" style="color:#ef4444; font-size:0.5rem; margin-right:6px; animation: pulse-glow 1.5s infinite;"></i> 32:15</span>
                        </div>
                        <div class="video-controls-center">
                            <button class="vc-btn" title="Mic"><i class="fas fa-microphone"></i></button>
                            <button class="vc-btn" title="Camera"><i class="fas fa-video"></i></button>
                            <button class="vc-btn" title="Screen Share"><i class="fas fa-desktop"></i></button>
                            <button class="vc-btn" title="Chat"><i class="fas fa-comment-dots"></i><span class="vc-btn-badge">3</span></button>
                            <button class="vc-btn" title="Reactions"><i class="fas fa-face-smile"></i></button>
                            <button class="vc-btn red-btn" title="End Call"><i class="fas fa-phone-slash"></i></button>
                        </div>
                        <div class="video-controls-right">
                            <button class="vc-btn" title="Participants"><i class="fas fa-users"></i><span class="vc-btn-badge">12</span></button>
                            <button class="vc-btn" title="More"><i class="fas fa-ellipsis-h"></i></button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ==================== TRUSTED BY ==================== -->
    <section class="trusted-section reveal" id="trusted">
        <div class="container">
            <p class="trusted-label">Trusted by the highest performance teams at</p>
            <div class="trusted-logos">
                <span class="trusted-logo">amazon</span>
                <span class="trusted-logo netflix">NETFLIX</span>
                <span class="trusted-logo"><i class="fab fa-spotify logo-icon"></i> Spotify</span>
                <span class="trusted-logo"><i class="fab fa-facebook logo-icon"></i> facebook</span>
                <span class="trusted-logo">yahoo!</span>
                <span class="trusted-logo"><i class="fab fa-microsoft logo-icon"></i> Microsoft</span>
            </div>
        </div>
    </section>

    <!-- ==================== STATS ==================== -->
    <section class="stats-section reveal" id="stats">
        <div class="container">
            <div class="stats-grid">
                <div class="stat-item">
                    <div class="stat-number" id="stat-1">50M+</div>
                    <div class="stat-label">meetings hosted every month across 190+ countries worldwide.</div>
                </div>
                <div class="stat-item">
                    <div class="stat-number" id="stat-2">99.9%</div>
                    <div class="stat-label">uptime guarantee with enterprise-grade reliability and security.</div>
                </div>
                <div class="stat-item">
                    <div class="stat-number" id="stat-3">500+</div>
                    <div class="stat-label">integrations with tools your team already uses and loves.</div>
                </div>
            </div>
        </div>
    </section>

    <!-- ==================== FEATURES ==================== -->
    <section class="features-section reveal" id="features">
        <div class="container">
            <div class="section-header">
                <h2 class="section-title">Add Flexibility, Not Complexity</h2>
                <p class="section-subtitle">Everything you need for productive meetings, all in one beautifully designed platform.</p>
            </div>

            <div class="features-grid">
                <div class="feature-card">
                    <div class="feature-icon green">
                        <i class="fas fa-lock"></i>
                    </div>
                    <h3 class="feature-title">Quick, secure access</h3>
                    <p class="feature-desc">Virtual meetings are easier than ever. No downloads necessary to join in. 80+ million annual online meetings.</p>
                </div>

                <div class="feature-card">
                    <div class="feature-icon purple">
                        <i class="fas fa-puzzle-piece"></i>
                    </div>
                    <h3 class="feature-title">Seamless integrations</h3>
                    <p class="feature-desc">Connect with your favorite tools like Slack, Google Calendar, and Microsoft Teams effortlessly.</p>
                </div>

                <div class="feature-card">
                    <div class="feature-icon blue">
                        <i class="fas fa-wand-magic-sparkles"></i>
                    </div>
                    <h3 class="feature-title">AI-powered features</h3>
                    <p class="feature-desc">Smart noise cancellation, auto-transcription, and real-time translations powered by advanced AI.</p>
                </div>

                <div class="feature-card">
                    <div class="feature-icon orange">
                        <i class="fas fa-chart-line"></i>
                    </div>
                    <h3 class="feature-title">Meeting analytics</h3>
                    <p class="feature-desc">Get insights into meeting engagement, attendance patterns, and team collaboration metrics.</p>
                </div>

                <div class="feature-card">
                    <div class="feature-icon pink">
                        <i class="fas fa-paintbrush"></i>
                    </div>
                    <h3 class="feature-title">Custom backgrounds</h3>
                    <p class="feature-desc">Choose from hundreds of virtual backgrounds or upload your own to look professional from anywhere.</p>
                </div>

                <div class="feature-card">
                    <div class="feature-icon teal">
                        <i class="fas fa-cloud"></i>
                    </div>
                    <h3 class="feature-title">Cloud recording</h3>
                    <p class="feature-desc">Record meetings to the cloud with unlimited storage. Access recordings anytime, from any device.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- ==================== TESTIMONIALS ==================== -->
    <section class="testimonials-section reveal" id="testimonials">
        <div class="container">
            <div class="testimonials-header">
                <h2 class="testimonials-title">What People Say<br>About Stream Connect</h2>
                <p class="testimonials-subtitle">Join thousands of satisfied users worldwide</p>
            </div>

            <!-- Auto-sliding testimonials -->
            <div class="testimonials-slider" id="testimonials-slider">
                <div class="testimonials-track" id="testimonials-track">
                    <!-- Card 1 -->
                    <div class="testimonial-card">
                        <div class="testimonial-stars"><span>★</span><span>★</span><span>★</span><span>★</span><span>★</span></div>
                        <p class="testimonial-text">"We switched from Zoom last year and haven't looked back. Stream Connect handles our 200-person all-hands flawlessly. The video quality is unmatched."</p>
                        <div class="testimonial-author">
                            <div class="testimonial-author-avatar" style="background: linear-gradient(135deg, #43e97b, #38f9d7);">RS</div>
                            <div>
                                <div class="testimonial-author-name">Rajesh Sharma</div>
                                <div class="testimonial-author-role">CTO, Infosync Technologies</div>
                            </div>
                        </div>
                    </div>
                    <!-- Card 2 -->
                    <div class="testimonial-card">
                        <div class="testimonial-stars"><span>★</span><span>★</span><span>★</span><span>★</span><span>★</span></div>
                        <p class="testimonial-text">"The AI noise cancellation is a lifesaver during monsoon season! No more background rain sounds. My clients always comment on how crisp the audio is."</p>
                        <div class="testimonial-author">
                            <div class="testimonial-author-avatar" style="background: linear-gradient(135deg, #fa709a, #fee140);">AP</div>
                            <div>
                                <div class="testimonial-author-name">Anjali Patel</div>
                                <div class="testimonial-author-role">Freelance Designer, Mumbai</div>
                            </div>
                        </div>
                    </div>
                    <!-- Card 3 -->
                    <div class="testimonial-card">
                        <div class="testimonial-stars"><span>★</span><span>★</span><span>★</span><span>★</span><span>★</span></div>
                        <p class="testimonial-text">"We run our entire remote engineering team on Stream Connect. The screen sharing and recording features save us hours every sprint. Highly recommended!"</p>
                        <div class="testimonial-author">
                            <div class="testimonial-author-avatar" style="background: linear-gradient(135deg, #667eea, #764ba2);">VK</div>
                            <div>
                                <div class="testimonial-author-name">Vikram Krishnan</div>
                                <div class="testimonial-author-role">Engineering Lead, CloudNine</div>
                            </div>
                        </div>
                    </div>
                    <!-- Card 4 -->
                    <div class="testimonial-card">
                        <div class="testimonial-stars"><span>★</span><span>★</span><span>★</span><span>★</span><span>★</span></div>
                        <p class="testimonial-text">"As a teacher, I needed something reliable for online classes. Stream Connect never drops my sessions and the whiteboard feature is brilliant for explaining concepts."</p>
                        <div class="testimonial-author">
                            <div class="testimonial-author-avatar" style="background: linear-gradient(135deg, #a18cd1, #fbc2eb);">DG</div>
                            <div>
                                <div class="testimonial-author-name">Deepa Gupta</div>
                                <div class="testimonial-author-role">Professor, IIT Delhi</div>
                            </div>
                        </div>
                    </div>
                    <!-- Card 5 -->
                    <div class="testimonial-card">
                        <div class="testimonial-stars"><span>★</span><span>★</span><span>★</span><span>★</span><span>★</span></div>
                        <p class="testimonial-text">"Our startup uses Stream Connect daily. It's faster to set up than Google Meet, more reliable than Zoom, and the free tier is incredibly generous. Best decision we made!"</p>
                        <div class="testimonial-author">
                            <div class="testimonial-author-avatar" style="background: linear-gradient(135deg, #f093fb, #f5576c);">AM</div>
                            <div>
                                <div class="testimonial-author-name">Arjun Malhotra</div>
                                <div class="testimonial-author-role">Founder, RapidBuild</div>
                            </div>
                        </div>
                    </div>
                    <!-- Card 6 -->
                    <div class="testimonial-card">
                        <div class="testimonial-stars"><span>★</span><span>★</span><span>★</span><span>★</span><span>★</span></div>
                        <p class="testimonial-text">"Managing a team across Bangalore, Pune and Hyderabad was chaotic before Stream Connect. Now our daily standups feel like we're in the same room. Love the reactions feature!"</p>
                        <div class="testimonial-author">
                            <div class="testimonial-author-avatar" style="background: linear-gradient(135deg, #4facfe, #00f2fe);">SM</div>
                            <div>
                                <div class="testimonial-author-name">Sneha Menon</div>
                                <div class="testimonial-author-role">PM, Wipro Digital</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Slider dots -->
            <div class="slider-dots" id="slider-dots"></div>
        </div>
    </section>

    <!-- ==================== FAQ ==================== -->
    <section class="faq-section reveal" id="faq">
        <div class="container">
            <div class="section-header">
                <h2 class="section-title">Frequently Asked Questions</h2>
                <p class="section-subtitle">Got questions? We've got answers.</p>
            </div>

            <div class="faq-grid">
                <div class="faq-item" id="faq-1">
                    <div class="faq-question" onclick="toggleFaq('faq-1')">
                        <span>Is Stream Connect the same as Zoom?</span>
                        <div class="faq-toggle">+</div>
                    </div>
                    <div class="faq-answer">
                        <div class="faq-answer-inner">
                            No, Stream Connect is a completely independent platform. While we offer similar video conferencing capabilities, Stream Connect is built with superior encryption, AI-powered features, and a more intuitive user experience designed for modern teams.
                        </div>
                    </div>
                </div>

                <div class="faq-item" id="faq-2">
                    <div class="faq-question" onclick="toggleFaq('faq-2')">
                        <span>Can I integrate Stream Connect with my conference room?</span>
                        <div class="faq-toggle">+</div>
                    </div>
                    <div class="faq-answer">
                        <div class="faq-answer-inner">
                            Absolutely! Stream Connect supports integration with major conference room systems including Poly, Cisco, and Crestron. Our Room Connector feature makes it easy to turn any meeting room into a smart conferencing space.
                        </div>
                    </div>
                </div>

                <div class="faq-item" id="faq-3">
                    <div class="faq-question" onclick="toggleFaq('faq-3')">
                        <span>How much does Stream Connect cost? Is there a free version?</span>
                        <div class="faq-toggle">+</div>
                    </div>
                    <div class="faq-answer">
                        <div class="faq-answer-inner">
                            Stream Connect offers a generous free tier with up to 40-minute group meetings and unlimited 1-on-1 calls. Pro plans start at $12.99/month with unlimited meeting duration, cloud recording, and advanced AI features.
                        </div>
                    </div>
                </div>

                <div class="faq-item" id="faq-4">
                    <div class="faq-question" onclick="toggleFaq('faq-4')">
                        <span>How does the GoTo Meeting free trial work?</span>
                        <div class="faq-toggle">+</div>
                    </div>
                    <div class="faq-answer">
                        <div class="faq-answer-inner">
                            Start your 14-day free trial with full access to all Pro features. No credit card required. At the end of your trial, you can choose to upgrade or continue with our free plan.
                        </div>
                    </div>
                </div>

                <div class="faq-item" id="faq-5">
                    <div class="faq-question" onclick="toggleFaq('faq-5')">
                        <span>How does the GoTo Meeting free trial work?</span>
                        <div class="faq-toggle">+</div>
                    </div>
                    <div class="faq-answer">
                        <div class="faq-answer-inner">
                            Our free trial gives you unrestricted access to every premium feature for 14 days. Simply sign up, no payment info needed, and experience the full power of Stream Connect conferencing.
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ==================== CTA SECTION ==================== -->
    <section class="cta-section reveal" id="cta">
        <div class="container">
            <h2 class="cta-title">Host Your Stream Connect<br>Meeting Today</h2>
            <p class="cta-subtitle">Start connecting with your team in seconds. No downloads required, no complicated setups.</p>
            <div class="cta-buttons">
                <% if(user) { %>
                    <form action="/newMeeting" method="POST" style="display:contents;">
                        <input type="hidden" name="username" value="<%= user.name %>">
                        <button type="submit" class="btn-cta">
                            <i class="fas fa-video"></i>
                            Start Free Meeting
                        </button>
                    </form>
                <% } else { %>
                    <button class="btn-cta" onclick="openModal('loginModal')">
                        <i class="fas fa-lock"></i>
                        Login to Start
                    </button>
                <% } %>
                <a href="#features" class="btn-cta-outline">
                    <i class="fas fa-play-circle"></i>
                    Watch Demo
                </a>
            </div>
        </div>
    </section>

    <!-- ==================== ACCESS SECTION ==================== -->
    <section class="download-section reveal" id="download">
        <div class="container">
            <div class="download-grid">
                <div class="download-content">
                    <div class="download-badge">
                        <i class="fas fa-globe"></i>
                        Available on Web
                    </div>
                    <h2 class="download-title">Works right in<br>your browser</h2>
