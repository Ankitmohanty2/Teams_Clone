<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Stream Connect - Meeting in Progress</title>
    <!-- Use home.css for base design tokens, then meeting.css for specific layout -->
    <link rel="stylesheet" href="/stylesheets/home.css">
    <link rel="stylesheet" href="/stylesheets/meeting.css">
    <link rel="icon" type="image/png" href="/logo.png">
    
    <script src="/socket.io/socket.io.js"></script>
    <script src="https://unpkg.com/peerjs@1.3.1/dist/peerjs.min.js"></script>
    <script src="https://kit.fontawesome.com/1d9b3c3ba8.js" crossorigin="anonymous"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qs/6.6.0/qs.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/clipboard@2.0.8/dist/clipboard.min.js"></script>
    
    <!-- No Bootstrap needed anymore, using custom UI -->
    <script>
        const { username, meetingCode } = Qs.parse(location.search, {ignoreQueryPrefix: true,});
    </script>
</head>
<body class="meeting-body">
    
    <!-- Top Header -->
    <header class="meeting-header">
        <div class="mh-left">
            <img src="/logo.png" alt="Stream Connect" class="mh-logo">
            <div class="mh-info">
                <h2>Stream Connect Meeting</h2>
                <span class="mh-code" id="copy-to-clipboard" title="Copy Meeting Code">
                    Code: <%= meetingCode %> <i class="fas fa-copy"></i>
                </span>
            </div>
        </div>
        <div class="mh-right">
            <div class="mh-timer"><i class="fas fa-circle recording-dot"></i> Live</div>
        </div>
    </header>

    <!-- Main Container -->
    <main id="meeting-container">
        
        <!-- Left: Video Grid & Controls -->
        <div class="meeting-main-content">
            <div id="meeting-video-grid" class="video-grid">
                <!-- Videos appended here via JS -->
            </div>

            <!-- Floating Control Bar -->
            <div id="meeting-controls" class="bottom-controls">
                <div class="ctrl-left">
                    <button id="meeting-mute" class="ctrl-btn active" onclick="audioControl()" title="Toggle Microphone">
                        <i class="fas fa-microphone"></i>
                    </button>
                    <button id="meeting-video-control" class="ctrl-btn active" onclick="videoControl()" title="Toggle Camera">
                        <i class="fas fa-video"></i>
                    </button>
                </div>
                
                <div class="ctrl-center">
                    <button class="ctrl-btn" onclick="openInviteModal()" title="Invite Participants">
                        <i class="fas fa-user-plus"></i>
                    </button>
                    <button class="ctrl-btn" onclick="toggleSidebar()" title="Chat & Participants">
                        <i class="fas fa-comment-dots"></i>
                    </button>
                </div>

                <div class="ctrl-right">
                    <a href="/" class="ctrl-btn leave-btn" title="Leave Meeting">
                        <i class="fas fa-phone-slash"></i> Leave
                    </a>
                </div>
            </div>
        </div>

        <!-- Right: Sidebar (Chat & Participants) -->
        <aside id="meeting-chat-and-participants" class="sidebar">
            <!-- Tabs -->
            <div class="sidebar-tabs">
                <button class="tab-btn active" onclick="switchTab('chat')">Chat</button>
                <button class="tab-btn" onclick="switchTab('participants')">People</button>
            </div>

            <!-- Participants Panel -->
            <div id="participants-panel" class="sidebar-panel hidden">
                <ul id="meeting-participants" class="participant-list">
                    <!-- Participants appended via JS -->
                </ul>
            </div>

            <!-- Chat Panel -->
            <div id="chat-panel" class="sidebar-panel active">
                <div id="meeting-chat-window" class="chat-window">
                    <ul id="meeting-chat-messages" class="chat-messages">
                        <!-- Chat messages appended via JS -->
                    </ul>
                </div>
                <div id="meeting-chat-input" class="chat-input-area">
                    <input id="message-input" type="text" placeholder="Send a message...">
                    <button class="chat-send-btn" title="Send Message">
                        <i class="fas fa-paper-plane"></i>
                    </button>
                </div>
            </div>
        </aside>

    </main>

    <!-- Invite Modal (Custom UI matching Auth Modals) -->
    <div class="custom-modal" id="inviteModal">
        <div class="custom-modal-content">
            <button class="close-modal" onclick="closeInviteModal()"><i class="fas fa-times"></i></button>
            <div class="modal-header">
                <h3>Invite Participants</h3>
                <p>Send an email invite directly from here.</p>
            </div>
            <form id="invite-form" class="modal-form">
                <input id="meeting-code" type="hidden" name="meetingCode" value="<%= meetingCode %>">
                <input id="sender" type="hidden" name="sender" value="<%= typeof user !== 'undefined' && user ? user.name : 'Guest' %>">
                <div class="input-group">
                    <i class="fas fa-envelope"></i>
                    <input id="receiver-email" type="email" name="email" placeholder="Participant's Email" required>
                </div>
                <button type="button" class="btn-primary" id="send-invite-btn" style="width:100%; margin-top:15px; justify-content:center;">Send Invite</button>
            </form>
        </div>
    </div>
    
    <script src="https://code.jquery.com/jquery-3.6.0.min.js" integrity="sha256-/xUj+3OJU5yExlq6GSYGSHk7tPXikynS7ogEvDej/m4=" crossorigin="anonymous"></script>
    <script src="scripts/meeting.js"></script>
    <script>
        // UI Interaction Script
        function toggleSidebar() {
            document.getElementById('meeting-chat-and-participants').classList.toggle('hidden');
        }
        function switchTab(tab) {
            document.querySelectorAll('.sidebar-tabs .tab-btn').forEach(btn => btn.classList.remove('active'));
            document.querySelectorAll('.sidebar-panel').forEach(panel => panel.classList.remove('active', 'hidden'));
            
            if(tab === 'chat') {
                document.querySelectorAll('.sidebar-tabs .tab-btn')[0].classList.add('active');
                document.getElementById('chat-panel').classList.add('active');
                document.getElementById('participants-panel').classList.add('hidden');
            } else {
                document.querySelectorAll('.sidebar-tabs .tab-btn')[1].classList.add('active');
                document.getElementById('participants-panel').classList.add('active');
                document.getElementById('chat-panel').classList.add('hidden');
            }
        }
        function openInviteModal() {
            document.getElementById('inviteModal').classList.add('active');
        }
        function closeInviteModal() {
            document.getElementById('inviteModal').classList.remove('active');
        }
    </script>
</body>
</html>
